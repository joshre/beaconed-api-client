{
  "name": "@beaconed/api-client",
  "version": "0.0.1",
  "description": "TypeScript HTTP client for the Beaconed v1 API",
  "keywords": [
    "beaconed",
    "api",
    "client",
    "ecommerce",
    "shopify",
    "seo",
    "product-optimization"
  ],
  "author": "Beaconed, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/beaconed/beaconed-api-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beaconed/beaconed-api-client.git"
  },
  "bugs": {
    "url": "https://github.com/beaconed/beaconed-api-client/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^8.57.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
